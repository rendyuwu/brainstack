# Database (PostgreSQL + pgvector)
DATABASE_URL=postgresql://noa:noa@localhost:5432/brainstack

# Auth (NextAuth.js v5)
# §V.44: AUTH_SECRET must be ≥ 32 characters. Generate with: openssl rand -base64 32
AUTH_SECRET=generate-with-openssl-rand-base64-32
AUTH_TRUST_HOST=true

# Seed script — admin user (required for pnpm seed)
# §V.44: SEED_ADMIN_PASSWORD must be ≥ 8 characters
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=change-me-min-8-chars
SEED_ADMIN_NAME=Admin

# Rate limiter — trusted proxy IPs (comma-separated)
# §V.51: Only set if behind a reverse proxy (e.g., nginx, Cloudflare)
# TRUSTED_PROXY_IPS=127.0.0.1,10.0.0.1

# E2E / Playwright smoke test user (optional, created by seed if set)
# E2E_EMAIL=smoke@example.com
# E2E_PASSWORD=smoke-test-password
